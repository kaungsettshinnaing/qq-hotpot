// QQ Hotpot BBQ — Prisma schema (PostgreSQL)
// POS + HR & Payroll + Inventory phase.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth / users
// ---------------------------------------------------------------------------

enum Role {
  WAITER
  KITCHEN
  CASHIER
  MANAGER
  ADMIN
  HR
  MARKETING
}

model User {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique
  passwordHash String
  pinHash      String? // manager approval PIN (e.g. void after send)
  roles            Role[]
  isActive         Boolean  @default(true)
  isSystemAccount  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt    DateTime @updatedAt

  openedSessions TableSession[] @relation("openedBy")
  closedSessions TableSession[] @relation("closedBy")
  orderItems     OrderItem[]
  potsCreated    PotOrder[]     @relation("potCreatedBy")
  potsDelivered  PotOrder[]     @relation("potDeliveredBy")
  payments       Payment[]
  reservations   Reservation[]
  expenses       Expense[]
  shifts         CashierShift[]

  // HR relations
  employee          Employee?
  uploadedDocuments EmployeeDocument[]  @relation("docUploadedBy")
  approvedAttendances Attendance[]      @relation("attendanceApprovedBy")
  reviewedLeaves    LeaveRequest[]      @relation("leaveReviewedBy")
  createdAdvances   SalaryAdvance[]     @relation("advanceCreatedBy")
  createdFines      EmployeeFine[]      @relation("fineCreatedBy")
  createdBonuses    AdHocBonus[]        @relation("bonusCreatedBy")
  lockedPayrolls    Payroll[]           @relation("payrollLockedBy")
  notifications     Notification[]

  cashCollections    CashCollection[]   @relation("CashCollectionRecorder")
  confirmedExpenses  Expense[]          @relation("ExpenseConfirmer")

  // Inventory relations
  deliveriesCreated  StockDelivery[]    @relation("DeliveryCreator")
  deliveriesCashier  StockDelivery[]    @relation("DeliveryCashier")
  deliveriesCounter  StockDelivery[]    @relation("DeliveryCounter")
  deliveriesResolved StockDelivery[]    @relation("DeliveryResolver")
  deliveryLogs       StockDeliveryLog[] @relation("DeliveryLogActor")
  stockMovements     StockMovement[]    @relation("MovementRecorder")
  stockCounts        StockCount[]       @relation("StockCountCreator")
  dailyReports       DailyReport[]      @relation("DailyReportAuthor")
}

// ---------------------------------------------------------------------------
// Floor: areas & tables
// ---------------------------------------------------------------------------

model Area {
  id        String  @id @default(cuid())
  name      String  @unique
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
  tables    Table[]
}

model Table {
  id       String  @id @default(cuid())
  area     Area    @relation(fields: [areaId], references: [id])
  areaId   String
  number   Int
  label    String  @unique // e.g. "A1"
  capacity Int?
  isActive Boolean @default(true)

  sessions     TableSession[]
  reservations Reservation[]
  mergeTo      TableMerge?

  @@unique([areaId, number])
}

// ---------------------------------------------------------------------------
// Menu & settings
// ---------------------------------------------------------------------------

enum MenuUnit {
  UNIT
  GRAM
}

model MenuItem {
  id       String   @id @default(cuid())
  code     String   @unique
  name     String
  category String   @default("")
  unit     MenuUnit     @default(UNIT)
  price    Int          @default(0)
  isActive Boolean      @default(true)
}

// Flexible key/value settings (freePotRatio, tax/service toggles, etc.)
model Setting {
  key       String   @id
  valueJson Json
  updatedAt DateTime @updatedAt
}

enum SoupApplies {
  HOTPOT
  BBQ
  BOTH
}

model SoupFlavour {
  id          String            @id @default(cuid())
  name        String            @unique
  appliesTo   SoupApplies       @default(BOTH)
  isActive    Boolean           @default(true)
  sortOrder   Int               @default(0)
  potFlavours PotOrderFlavour[]
}

// ---------------------------------------------------------------------------
// Orders: table sessions, items, pots
// ---------------------------------------------------------------------------

enum SessionStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum DiscountType {
  PERCENT
  FIXED
}

model TableSession {
  id             String        @id @default(cuid())
  table          Table         @relation(fields: [tableId], references: [id])
  tableId        String
  openedBy       User          @relation("openedBy", fields: [openedById], references: [id])
  openedById     String
  openedAt       DateTime      @default(now())
  adults         Int           @default(0)
  children       Int           @default(0)
  wastageGrams   Int           @default(0)
  status         SessionStatus @default(OPEN)
  closedBy       User?         @relation("closedBy", fields: [closedById], references: [id])
  closedById     String?
  closedAt       DateTime?
  billTotal      Int?          // stored at settlement; used to compute change given
  discountType   DiscountType?
  discountValue  Int?
  discountReason String?
  note           String?

  orderItems   OrderItem[]
  potOrders    PotOrder[]
  payments     Payment[]
  mergedTables TableMerge[]

  @@index([tableId, status])
  @@index([status])
}

model TableMerge {
  id        String       @id @default(cuid())
  session   TableSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  table     Table        @relation(fields: [tableId], references: [id])
  tableId   String       @unique
}

model OrderItem {
  id          String       @id @default(cuid())
  session     TableSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId   String
  itemCode    String       // BEER, SOFT_DRINK, etc.
  qty         Int          @default(1)
  unitPrice   Int          @default(0) // price snapshot at time of order
  createdBy   User         @relation(fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime     @default(now())
  voidedAt    DateTime?

  @@index([sessionId])
}

enum PotKind {
  HOTPOT
  BBQ
}

enum PotStatus {
  PENDING
  DELIVERED
}

model PotOrder {
  id            String       @id @default(cuid())
  session       TableSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId     String
  kind          PotKind
  isFree        Boolean      @default(false)
  status        PotStatus    @default(PENDING)
  createdBy     User         @relation("potCreatedBy", fields: [createdById], references: [id])
  createdById   String
  createdAt     DateTime     @default(now())
  deliveredBy   User?        @relation("potDeliveredBy", fields: [deliveredById], references: [id])
  deliveredById String?
  deliveredAt   DateTime?
  voidedAt      DateTime?

  flavours PotOrderFlavour[]

  @@index([sessionId])
  @@index([status])
}

model PotOrderFlavour {
  id         String      @id @default(cuid())
  potOrder   PotOrder    @relation(fields: [potOrderId], references: [id], onDelete: Cascade)
  potOrderId String
  flavour    SoupFlavour @relation(fields: [flavourId], references: [id])
  flavourId  String

  @@index([potOrderId])
}

// ---------------------------------------------------------------------------
// Payments
// ---------------------------------------------------------------------------

enum PaymentMethod {
  CASH
  KBZPAY
  OTHER
}

model Payment {
  id           String        @id @default(cuid())
  session      TableSession  @relation(fields: [sessionId], references: [id])
  sessionId    String
  shift        CashierShift? @relation(fields: [shiftId], references: [id])
  shiftId      String?
  method       PaymentMethod
  amount       Int
  reference    String?
  receivedBy   User          @relation(fields: [receivedById], references: [id])
  receivedById String
  receivedAt   DateTime      @default(now())
  reconciledAt DateTime?     // set by admin when KBZPay/OTHER is confirmed received

  @@index([sessionId])
  @@index([shiftId])
}

// ---------------------------------------------------------------------------
// Reservations
// ---------------------------------------------------------------------------

enum ReservationStatus {
  BOOKED
  SEATED
  CANCELLED
  NO_SHOW
}

model Reservation {
  id           String            @id @default(cuid())
  table        Table?            @relation(fields: [tableId], references: [id])
  tableId      String?
  customerName String
  phone        String?
  partySize    Int
  bookingAt    DateTime
  durationMin  Int               @default(120)
  status       ReservationStatus @default(BOOKED)
  note         String?
  createdBy    User              @relation(fields: [createdById], references: [id])
  createdById  String
  createdAt    DateTime          @default(now())

  @@index([tableId, bookingAt])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Expenses
// ---------------------------------------------------------------------------

model ExpenseCategory {
  id       String    @id @default(cuid())
  name     String    @unique
  isStock  Boolean   @default(false) // true = linked to stock deliveries
  isActive Boolean   @default(true)
  expenses Expense[]
}

enum ExpenseSource {
  CASH_DRAWER // paid from cashier cash -> affects reconciliation
  BANK_TRANSFER // does NOT affect cashier cash
}

model Expense {
  id            String          @id @default(cuid())
  businessDate  DateTime
  category      ExpenseCategory @relation(fields: [categoryId], references: [id])
  categoryId    String
  amount        Int
  paymentSource ExpenseSource
  description   String
  vendor        String?
  shift         CashierShift?   @relation(fields: [shiftId], references: [id])
  shiftId       String?
  enteredBy     User            @relation(fields: [enteredById], references: [id])
  enteredById   String
  receiptUrl    String?
  paidAt        DateTime?       // set by admin when BANK_TRANSFER expense is confirmed paid
  confirmedAt   DateTime?       // set by manager when expense receipt is verified
  confirmedById String?
  confirmedBy   User?           @relation("ExpenseConfirmer", fields: [confirmedById], references: [id])
  attachments   ExpenseAttachment[]
  createdAt     DateTime        @default(now())

  @@index([businessDate])
  @@index([shiftId])
  @@index([confirmedAt])
}

model ExpenseAttachment {
  id        String   @id @default(cuid())
  expense   Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  expenseId String
  filePath  String   // relative path under uploads dir, e.g. "receipts/abc.jpg"
  createdAt DateTime @default(now())

  @@index([expenseId])
}

// ---------------------------------------------------------------------------
// Cashier shift / cash reconciliation
// ---------------------------------------------------------------------------

enum ShiftStatus {
  OPEN
  CLOSED
}

model CashierShift {
  id           String      @id @default(cuid())
  cashier      User        @relation(fields: [cashierId], references: [id])
  cashierId    String
  openedAt     DateTime    @default(now())
  openingFloat Int         @default(0)
  closedAt     DateTime?
  countedCash  Int?
  expectedCash Int?
  variance     Int?
  status       ShiftStatus @default(OPEN)
  note         String?

  payments Payment[]
  expenses Expense[]

  @@index([cashierId, status])
}

// ---------------------------------------------------------------------------
// HR & Payroll
// ---------------------------------------------------------------------------

// Custom job roles defined by admin (e.g. "Head Waiter", "Kitchen Lead")
model StaffRole {
  id          String    @id @default(cuid())
  name        String    @unique
  permissions Role[]    // system permissions this role grants
  isActive    Boolean   @default(true)
  employees   Employee[]
}

model Employee {
  userId           String     @id
  user             User       @relation(fields: [userId], references: [id])
  staffRole        StaffRole? @relation(fields: [staffRoleId], references: [id])
  staffRoleId      String?
  employeeNo       String?    @unique
  dateOfBirth      DateTime?
  phone            String?
  address          String?
  emergencyContact String?
  bankAccount      String?
  startDate        DateTime
  endDate          DateTime?
  basicSalary      Int        @default(0)
  attendanceBonus  Int        @default(0)
  restDays         Int[]      // weekday numbers 0=Sun … 6=Sat
  isActive         Boolean    @default(true)
  isSystem         Boolean    @default(false) // login-only; excluded from attendance & payroll

  customValues  EmployeeFieldValue[]
  documents     EmployeeDocument[]
  attendances   Attendance[]
  leaveRequests LeaveRequest[]
  advances      SalaryAdvance[]
  fines         EmployeeFine[]
  adHocBonuses  AdHocBonus[]
  payrollItems  PayrollItem[]
}

// Admin-defined extra profile fields
enum FieldType {
  TEXT
  NUMBER
  DATE
  DROPDOWN
}

model EmployeeFieldDef {
  id        String    @id @default(cuid())
  label     String
  fieldType FieldType @default(TEXT)
  options   String[]  // only used for DROPDOWN
  isRequired Boolean  @default(false)
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)

  values EmployeeFieldValue[]
}

model EmployeeFieldValue {
  id         String           @id @default(cuid())
  employee   Employee         @relation(fields: [employeeId], references: [userId])
  employeeId String
  fieldDef   EmployeeFieldDef @relation(fields: [fieldDefId], references: [id])
  fieldDefId String
  value      String

  @@unique([employeeId, fieldDefId])
  @@index([employeeId])
}

model EmployeeDocument {
  id           String   @id @default(cuid())
  employee     Employee @relation(fields: [employeeId], references: [userId])
  employeeId   String
  name         String
  filePath     String
  uploadedBy   User     @relation("docUploadedBy", fields: [uploadedById], references: [id])
  uploadedById String
  uploadedAt   DateTime @default(now())

  @@index([employeeId])
}

// Attendance
enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  REST_DAY
  OT
}

enum DayType {
  FULL
  HALF
}

model Attendance {
  id           String           @id @default(cuid())
  employee     Employee         @relation(fields: [employeeId], references: [userId])
  employeeId   String
  date         DateTime         @db.Date
  status       AttendanceStatus @default(PRESENT)
  dayType      DayType          @default(FULL)
  clockInAt    DateTime?
  clockOutAt   DateTime?
  isApproved   Boolean          @default(false)
  approvedBy   User?            @relation("attendanceApprovedBy", fields: [approvedById], references: [id])
  approvedById String?
  note         String?
  breaks       AttendanceBreak[]

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
}

model AttendanceBreak {
  id           String     @id @default(cuid())
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  attendanceId String
  startAt      DateTime
  endAt        DateTime?
  createdAt    DateTime   @default(now())

  @@index([attendanceId])
}

// Leave requests
enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model LeaveRequest {
  id           String      @id @default(cuid())
  employee     Employee    @relation(fields: [employeeId], references: [userId])
  employeeId   String
  startDate    DateTime    @db.Date
  endDate      DateTime    @db.Date
  reason       String?
  status       LeaveStatus @default(PENDING)
  reviewedBy   User?       @relation("leaveReviewedBy", fields: [reviewedById], references: [id])
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime    @default(now())

  @@index([employeeId])
  @@index([status])
}

// Salary advances
model SalaryAdvance {
  id          String   @id @default(cuid())
  employee    Employee @relation(fields: [employeeId], references: [userId])
  employeeId  String
  totalAmount Int
  note        String?
  createdBy   User     @relation("advanceCreatedBy", fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime @default(now())

  instalments AdvanceInstalment[]

  @@index([employeeId])
}

model AdvanceInstalment {
  id        String        @id @default(cuid())
  advance   SalaryAdvance @relation(fields: [advanceId], references: [id], onDelete: Cascade)
  advanceId String
  month     Int
  year      Int
  amount    Int
  deducted  Boolean       @default(false)

  @@index([advanceId])
  @@index([year, month])
}

// Fines
model EmployeeFine {
  id          String   @id @default(cuid())
  employee    Employee @relation(fields: [employeeId], references: [userId])
  employeeId  String
  amount      Int
  reason      String
  deductMonth Int
  deductYear  Int
  deducted    Boolean  @default(false)
  createdBy   User     @relation("fineCreatedBy", fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime @default(now())

  @@index([employeeId])
  @@index([deductYear, deductMonth])
}

// Ad-hoc bonuses
model AdHocBonus {
  id          String   @id @default(cuid())
  employee    Employee @relation(fields: [employeeId], references: [userId])
  employeeId  String
  amount      Int
  label       String
  month       Int
  year        Int
  createdBy   User     @relation("bonusCreatedBy", fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime @default(now())

  @@index([employeeId])
  @@index([year, month])
}

// Payroll
enum PayrollStatus {
  DRAFT
  LOCKED
}

model Payroll {
  id         String        @id @default(cuid())
  month      Int
  year       Int
  status     PayrollStatus @default(DRAFT)
  lockedAt   DateTime?
  lockedBy   User?         @relation("payrollLockedBy", fields: [lockedById], references: [id])
  lockedById String?
  createdAt  DateTime      @default(now())

  items PayrollItem[]

  @@unique([month, year])
}

model PayrollItem {
  id                   String   @id @default(cuid())
  payroll              Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  payrollId            String
  employee             Employee @relation(fields: [employeeId], references: [userId])
  employeeId           String
  basicSalary          Int
  workingDays          Int
  absentDays           Int
  otDays               Int
  attendanceBonusAmt   Int
  dailyRate            Int
  absenceDeduction     Int
  otPremium            Int
  adHocBonuses         Int
  advanceDeduction     Int
  fineDeduction        Int
  netPay               Int

  @@unique([payrollId, employeeId])
  @@index([payrollId])
  @@index([employeeId])
}

// ---------------------------------------------------------------------------
// Inventory
// ---------------------------------------------------------------------------

enum StockUnit {
  UNIT
  GRAM
  KG
  LITRE
  BOX
  BOTTLE
  PACK
}

enum DeliveryStatus {
  DRAFT          // created, no action yet
  PREPAID        // paid upfront, goods still at vendor
  OPEN           // goods arrived, awaiting cashier + counter input
  PENDING_REVIEW // both sides submitted, discrepancy flagged to manager
  PARTIAL        // this batch reconciled, more expected
  COMPLETE       // all items received and reconciled
}

enum PaymentStatus {
  UNPAID   // pay on delivery
  PREPAID  // paid in advance, goods pending
  PAID     // paid at time of delivery
}

enum MovementType {
  DELIVERY_IN // stock received via delivery
  USAGE_OUT   // stock consumed/used
  ADJUSTMENT  // manual stock correction
}

enum InvoiceType {
  STOCK
  NON_STOCK
}

enum StockCountType {
  SPOT    // random daily check of ≥5% items
  WEEKLY  // full weekly count
}

model Supplier {
  id         String          @id @default(cuid())
  name       String
  contact    String?
  phone      String?
  address    String?
  notes      String?
  isActive   Boolean         @default(true)
  createdAt  DateTime        @default(now())
  deliveries StockDelivery[]
}

model StockCategory {
  id        String      @id @default(cuid())
  name      String
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  items     StockItem[]
}

model StockItem {
  id           String              @id @default(cuid())
  name         String
  categoryId   String?
  category     StockCategory?      @relation(fields: [categoryId], references: [id])
  unit         StockUnit           @default(UNIT)
  minStock     Int?                // below this → "Low Stock" red alert
  optimalStock Int?                // target level; order qty = optimalStock − currentStock
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  deliveryItems StockDeliveryItem[]
  movements    StockMovement[]
  countItems   StockCountItem[]
}

model StockDelivery {
  id             String         @id @default(cuid())
  deliveryDate   DateTime
  invoiceNo      String?
  supplierId     String?
  supplier       Supplier?      @relation(fields: [supplierId], references: [id])
  status         DeliveryStatus @default(DRAFT)
  paymentStatus  PaymentStatus  @default(UNPAID)
  invoiceType    InvoiceType    @default(STOCK)
  prepaidAt      DateTime?

  // Batch delivery link (optional — for partial orders)
  parentDeliveryId String?
  parentDelivery   StockDelivery?  @relation("DeliveryBatches", fields: [parentDeliveryId], references: [id])
  batches          StockDelivery[] @relation("DeliveryBatches")

  // Cashier side (invoice data + payment)
  cashierEnteredById  String?
  cashierEnteredBy    User?         @relation("DeliveryCashier", fields: [cashierEnteredById], references: [id])
  cashierSubmittedAt  DateTime?
  totalCost           Int?          // Σ orderedQty × unitCost (expense amount)
  paymentSource       ExpenseSource?
  expenseId           String?       @unique // linked Expense created at payment time

  // Counter side (physical count by waiter/kitchen)
  counterEnteredById  String?
  counterEnteredBy    User?         @relation("DeliveryCounter", fields: [counterEnteredById], references: [id])
  counterSubmittedAt  DateTime?

  // Manager resolution
  resolvedById   String?
  resolvedBy     User?             @relation("DeliveryResolver", fields: [resolvedById], references: [id])
  resolvedAt     DateTime?
  resolutionNote String?

  createdById  String
  createdBy    User               @relation("DeliveryCreator", fields: [createdById], references: [id])
  createdAt    DateTime           @default(now())

  items StockDeliveryItem[]
  logs  StockDeliveryLog[]

  @@index([status])
  @@index([supplierId])
}

model StockDeliveryItem {
  id          String        @id @default(cuid())
  deliveryId  String
  delivery    StockDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  stockItemId String?
  stockItem   StockItem?    @relation(fields: [stockItemId], references: [id])
  description String?       // for NON_STOCK invoice lines (free text)
  unitLabel   String?       // free-text unit for NON_STOCK lines
  orderedQty  Int?          // total qty on the purchase order (spans all batches)
  cashierQty  Int?          // this batch — from invoice
  counterQty  Int?          // this batch — from physical count
  finalQty    Int?          // set on COMPLETE/PARTIAL for this batch
  unitCost    Int?          // MMK per unit

  @@unique([deliveryId, stockItemId])
  @@index([deliveryId])
}

model StockDeliveryLog {
  id         String        @id @default(cuid())
  deliveryId String
  delivery   StockDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  actorId    String
  actor      User          @relation("DeliveryLogActor", fields: [actorId], references: [id])
  action     String        // CREATED | PREPAID | CASHIER_SUBMITTED | COUNTER_SUBMITTED | AUTO_COMPLETED | MANAGER_RESOLVED | MARKED_PARTIAL
  note       String?
  createdAt  DateTime      @default(now())

  @@index([deliveryId])
}

model StockMovement {
  id           String       @id @default(cuid())
  stockItemId  String
  stockItem    StockItem    @relation(fields: [stockItemId], references: [id])
  type         MovementType
  qty          Int          // positive = in, negative = out
  previousQty  Int?         // stock level before this movement (for ADJUSTMENT)
  note         String?
  deliveryId   String?      // set for DELIVERY_IN movements
  recordedById String
  recordedBy   User         @relation("MovementRecorder", fields: [recordedById], references: [id])
  createdAt    DateTime     @default(now())

  @@index([stockItemId])
  @@index([createdAt])
}

model StockCount {
  id          String           @id @default(cuid())
  date        DateTime         @db.Date
  type        StockCountType
  createdById String
  createdBy   User             @relation("StockCountCreator", fields: [createdById], references: [id])
  completedAt DateTime?
  note        String?
  items       StockCountItem[]
  createdAt   DateTime         @default(now())

  @@index([date])
}

model StockCountItem {
  id          String     @id @default(cuid())
  countId     String
  count       StockCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  stockItemId String
  stockItem   StockItem  @relation(fields: [stockItemId], references: [id])
  systemQty   Int
  actualQty   Int?
  confirmed   Boolean    @default(false)
  note        String?

  @@unique([countId, stockItemId])
  @@index([countId])
}

// ---------------------------------------------------------------------------
// Cash collection / injection log
// ---------------------------------------------------------------------------

enum CollectionType {
  COLLECT // admin takes money out of drawer
  INJECT  // admin adds money into drawer
}

model CashCollection {
  id           String         @id @default(cuid())
  type         CollectionType
  amount       Int
  note         String?
  recordedById String
  recordedBy   User           @relation("CashCollectionRecorder", fields: [recordedById], references: [id])
  createdAt    DateTime       @default(now())

  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// In-app notifications (for managers: break events, leave requests, etc.)
enum NotifType {
  BREAK_OUT
  BREAK_IN
  LEAVE_REQUEST
  ATTENDANCE_APPROVED
  LEAVE_APPROVED
  LEAVE_REJECTED
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  type      NotifType
  message   String
  isRead    Boolean   @default(false)
  relatedId String?
  createdAt DateTime  @default(now())

  @@index([userId, isRead])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Daily manager report
// ---------------------------------------------------------------------------

model DailyReport {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  content     String
  createdById String
  createdBy   User     @relation("DailyReportAuthor", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([date])
  @@index([createdById])
}
