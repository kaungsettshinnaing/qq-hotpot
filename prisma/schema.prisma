// QQ Hotpot BBQ — Prisma schema (PostgreSQL)
// POS + HR & Payroll phase.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth / users
// ---------------------------------------------------------------------------

enum Role {
  WAITER
  KITCHEN
  CASHIER
  MANAGER
  ADMIN
  HR
  MARKETING
}

model User {
  id           String   @id @default(cuid())
  name         String
  username     String   @unique
  passwordHash String
  pinHash      String? // manager approval PIN (e.g. void after send)
  roles        Role[]
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  openedSessions TableSession[] @relation("openedBy")
  closedSessions TableSession[] @relation("closedBy")
  orderItems     OrderItem[]
  potsCreated    PotOrder[]     @relation("potCreatedBy")
  potsDelivered  PotOrder[]     @relation("potDeliveredBy")
  payments       Payment[]
  reservations   Reservation[]
  expenses       Expense[]
  shifts         CashierShift[]

  // HR relations
  employee          Employee?
  uploadedDocuments EmployeeDocument[]  @relation("docUploadedBy")
  approvedAttendances Attendance[]      @relation("attendanceApprovedBy")
  reviewedLeaves    LeaveRequest[]      @relation("leaveReviewedBy")
  createdAdvances   SalaryAdvance[]     @relation("advanceCreatedBy")
  createdFines      EmployeeFine[]      @relation("fineCreatedBy")
  createdBonuses    AdHocBonus[]        @relation("bonusCreatedBy")
  lockedPayrolls    Payroll[]           @relation("payrollLockedBy")
  notifications     Notification[]
}

// ---------------------------------------------------------------------------
// Floor: areas & tables
// ---------------------------------------------------------------------------

model Area {
  id        String  @id @default(cuid())
  name      String  @unique
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
  tables    Table[]
}

model Table {
  id       String  @id @default(cuid())
  area     Area    @relation(fields: [areaId], references: [id])
  areaId   String
  number   Int
  label    String  @unique // e.g. "A1"
  capacity Int?
  isActive Boolean @default(true)

  sessions     TableSession[]
  reservations Reservation[]

  @@unique([areaId, number])
}

// ---------------------------------------------------------------------------
// Menu & settings
// ---------------------------------------------------------------------------

enum MenuItemCode {
  ADULT
  CHILD
  BEER
  POT_ADDON
  WASTAGE
}

enum MenuUnit {
  UNIT
  GRAM
}

model MenuItem {
  id       String       @id @default(cuid())
  code     MenuItemCode @unique
  name     String
  unit     MenuUnit     @default(UNIT)
  price    Int          @default(0) // MMK per unit (or per gram for WASTAGE)
  isActive Boolean      @default(true)
}

// Flexible key/value settings (freePotRatio, tax/service toggles, etc.)
model Setting {
  key       String   @id
  valueJson Json
  updatedAt DateTime @updatedAt
}

enum SoupApplies {
  HOTPOT
  BBQ
  BOTH
}

model SoupFlavour {
  id          String            @id @default(cuid())
  name        String            @unique
  appliesTo   SoupApplies       @default(BOTH)
  isActive    Boolean           @default(true)
  sortOrder   Int               @default(0)
  potFlavours PotOrderFlavour[]
}

// ---------------------------------------------------------------------------
// Orders: table sessions, items, pots
// ---------------------------------------------------------------------------

enum SessionStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum DiscountType {
  PERCENT
  FIXED
}

model TableSession {
  id             String        @id @default(cuid())
  table          Table         @relation(fields: [tableId], references: [id])
  tableId        String
  openedBy       User          @relation("openedBy", fields: [openedById], references: [id])
  openedById     String
  openedAt       DateTime      @default(now())
  adults         Int           @default(0)
  children       Int           @default(0)
  wastageGrams   Int           @default(0)
  status         SessionStatus @default(OPEN)
  closedBy       User?         @relation("closedBy", fields: [closedById], references: [id])
  closedById     String?
  closedAt       DateTime?
  discountType   DiscountType?
  discountValue  Int?
  discountReason String?
  note           String?

  orderItems OrderItem[]
  potOrders  PotOrder[]
  payments   Payment[]

  @@index([tableId, status])
  @@index([status])
}

model OrderItem {
  id          String       @id @default(cuid())
  session     TableSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId   String
  itemCode    MenuItemCode // BEER (extensible to future a-la-carte items)
  qty         Int          @default(1)
  unitPrice   Int          @default(0) // price snapshot at time of order
  createdBy   User         @relation(fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime     @default(now())
  voidedAt    DateTime?

  @@index([sessionId])
}

enum PotKind {
  HOTPOT
  BBQ
}

enum PotStatus {
  PENDING
  DELIVERED
}

model PotOrder {
  id            String       @id @default(cuid())
  session       TableSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId     String
  kind          PotKind
  isFree        Boolean      @default(false)
  status        PotStatus    @default(PENDING)
  createdBy     User         @relation("potCreatedBy", fields: [createdById], references: [id])
  createdById   String
  createdAt     DateTime     @default(now())
  deliveredBy   User?        @relation("potDeliveredBy", fields: [deliveredById], references: [id])
  deliveredById String?
  deliveredAt   DateTime?
  voidedAt      DateTime?

  flavours PotOrderFlavour[]

  @@index([sessionId])
  @@index([status])
}

model PotOrderFlavour {
  id         String      @id @default(cuid())
  potOrder   PotOrder    @relation(fields: [potOrderId], references: [id], onDelete: Cascade)
  potOrderId String
  flavour    SoupFlavour @relation(fields: [flavourId], references: [id])
  flavourId  String

  @@index([potOrderId])
}

// ---------------------------------------------------------------------------
// Payments
// ---------------------------------------------------------------------------

enum PaymentMethod {
  CASH
  KBZPAY
  OTHER
}

model Payment {
  id           String        @id @default(cuid())
  session      TableSession  @relation(fields: [sessionId], references: [id])
  sessionId    String
  shift        CashierShift? @relation(fields: [shiftId], references: [id])
  shiftId      String?
  method       PaymentMethod
  amount       Int
  reference    String?
  receivedBy   User          @relation(fields: [receivedById], references: [id])
  receivedById String
  receivedAt   DateTime      @default(now())

  @@index([sessionId])
  @@index([shiftId])
}

// ---------------------------------------------------------------------------
// Reservations
// ---------------------------------------------------------------------------

enum ReservationStatus {
  BOOKED
  SEATED
  CANCELLED
  NO_SHOW
}

model Reservation {
  id           String            @id @default(cuid())
  table        Table?            @relation(fields: [tableId], references: [id])
  tableId      String?
  customerName String
  phone        String?
  partySize    Int
  bookingAt    DateTime
  durationMin  Int               @default(120)
  status       ReservationStatus @default(BOOKED)
  note         String?
  createdBy    User              @relation(fields: [createdById], references: [id])
  createdById  String
  createdAt    DateTime          @default(now())

  @@index([tableId, bookingAt])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Expenses
// ---------------------------------------------------------------------------

model ExpenseCategory {
  id       String    @id @default(cuid())
  name     String    @unique
  isActive Boolean   @default(true)
  expenses Expense[]
}

enum ExpenseSource {
  CASH_DRAWER // paid from cashier cash -> affects reconciliation
  BANK_TRANSFER // does NOT affect cashier cash
}

model Expense {
  id            String          @id @default(cuid())
  businessDate  DateTime
  category      ExpenseCategory @relation(fields: [categoryId], references: [id])
  categoryId    String
  amount        Int
  paymentSource ExpenseSource
  description   String
  vendor        String?
  shift         CashierShift?   @relation(fields: [shiftId], references: [id])
  shiftId       String?
  enteredBy     User            @relation(fields: [enteredById], references: [id])
  enteredById   String
  receiptUrl    String?
  createdAt     DateTime        @default(now())

  @@index([businessDate])
  @@index([shiftId])
}

// ---------------------------------------------------------------------------
// Cashier shift / cash reconciliation
// ---------------------------------------------------------------------------

enum ShiftStatus {
  OPEN
  CLOSED
}

model CashierShift {
  id           String      @id @default(cuid())
  cashier      User        @relation(fields: [cashierId], references: [id])
  cashierId    String
  openedAt     DateTime    @default(now())
  openingFloat Int         @default(0)
  closedAt     DateTime?
  countedCash  Int?
  expectedCash Int?
  variance     Int?
  status       ShiftStatus @default(OPEN)
  note         String?

  payments Payment[]
  expenses Expense[]

  @@index([cashierId, status])
}

// ---------------------------------------------------------------------------
// HR & Payroll
// ---------------------------------------------------------------------------

model Employee {
  userId           String    @id
  user             User      @relation(fields: [userId], references: [id])
  employeeNo       String?   @unique
  dateOfBirth      DateTime?
  phone            String?
  address          String?
  emergencyContact String?
  bankAccount      String?
  startDate        DateTime
  endDate          DateTime?
  basicSalary      Int       @default(0)
  attendanceBonus  Int       @default(0)
  restDays         Int[]     // weekday numbers 0=Sun … 6=Sat
  isActive         Boolean   @default(true)

  customValues  EmployeeFieldValue[]
  documents     EmployeeDocument[]
  attendances   Attendance[]
  leaveRequests LeaveRequest[]
  advances      SalaryAdvance[]
  fines         EmployeeFine[]
  adHocBonuses  AdHocBonus[]
  payrollItems  PayrollItem[]
}

// Admin-defined extra profile fields
enum FieldType {
  TEXT
  NUMBER
  DATE
  DROPDOWN
}

model EmployeeFieldDef {
  id        String    @id @default(cuid())
  label     String
  fieldType FieldType @default(TEXT)
  options   String[]  // only used for DROPDOWN
  isRequired Boolean  @default(false)
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)

  values EmployeeFieldValue[]
}

model EmployeeFieldValue {
  id         String           @id @default(cuid())
  employee   Employee         @relation(fields: [employeeId], references: [userId])
  employeeId String
  fieldDef   EmployeeFieldDef @relation(fields: [fieldDefId], references: [id])
  fieldDefId String
  value      String

  @@unique([employeeId, fieldDefId])
  @@index([employeeId])
}

model EmployeeDocument {
  id           String   @id @default(cuid())
  employee     Employee @relation(fields: [employeeId], references: [userId])
  employeeId   String
  name         String
  filePath     String
  uploadedBy   User     @relation("docUploadedBy", fields: [uploadedById], references: [id])
  uploadedById String
  uploadedAt   DateTime @default(now())

  @@index([employeeId])
}

// Attendance
enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  REST_DAY
  OT
}

model Attendance {
  id           String           @id @default(cuid())
  employee     Employee         @relation(fields: [employeeId], references: [userId])
  employeeId   String
  date         DateTime         @db.Date
  status       AttendanceStatus @default(PRESENT)
  clockInAt    DateTime?
  clockOutAt   DateTime?
  breakOutAt   DateTime?
  breakInAt    DateTime?
  isApproved   Boolean          @default(false)
  approvedBy   User?            @relation("attendanceApprovedBy", fields: [approvedById], references: [id])
  approvedById String?
  note         String?

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
}

// Leave requests
enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model LeaveRequest {
  id           String      @id @default(cuid())
  employee     Employee    @relation(fields: [employeeId], references: [userId])
  employeeId   String
  startDate    DateTime    @db.Date
  endDate      DateTime    @db.Date
  reason       String?
  status       LeaveStatus @default(PENDING)
  reviewedBy   User?       @relation("leaveReviewedBy", fields: [reviewedById], references: [id])
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime    @default(now())

  @@index([employeeId])
  @@index([status])
}

// Salary advances
model SalaryAdvance {
  id          String   @id @default(cuid())
  employee    Employee @relation(fields: [employeeId], references: [userId])
  employeeId  String
  totalAmount Int
  note        String?
  createdBy   User     @relation("advanceCreatedBy", fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime @default(now())

  instalments AdvanceInstalment[]

  @@index([employeeId])
}

model AdvanceInstalment {
  id        String        @id @default(cuid())
  advance   SalaryAdvance @relation(fields: [advanceId], references: [id], onDelete: Cascade)
  advanceId String
  month     Int
  year      Int
  amount    Int
  deducted  Boolean       @default(false)

  @@index([advanceId])
  @@index([year, month])
}

// Fines
model EmployeeFine {
  id          String   @id @default(cuid())
  employee    Employee @relation(fields: [employeeId], references: [userId])
  employeeId  String
  amount      Int
  reason      String
  deductMonth Int
  deductYear  Int
  deducted    Boolean  @default(false)
  createdBy   User     @relation("fineCreatedBy", fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime @default(now())

  @@index([employeeId])
  @@index([deductYear, deductMonth])
}

// Ad-hoc bonuses
model AdHocBonus {
  id          String   @id @default(cuid())
  employee    Employee @relation(fields: [employeeId], references: [userId])
  employeeId  String
  amount      Int
  label       String
  month       Int
  year        Int
  createdBy   User     @relation("bonusCreatedBy", fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime @default(now())

  @@index([employeeId])
  @@index([year, month])
}

// Payroll
enum PayrollStatus {
  DRAFT
  LOCKED
}

model Payroll {
  id         String        @id @default(cuid())
  month      Int
  year       Int
  status     PayrollStatus @default(DRAFT)
  lockedAt   DateTime?
  lockedBy   User?         @relation("payrollLockedBy", fields: [lockedById], references: [id])
  lockedById String?
  createdAt  DateTime      @default(now())

  items PayrollItem[]

  @@unique([month, year])
}

model PayrollItem {
  id                   String   @id @default(cuid())
  payroll              Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  payrollId            String
  employee             Employee @relation(fields: [employeeId], references: [userId])
  employeeId           String
  basicSalary          Int
  workingDays          Int
  absentDays           Int
  otDays               Int
  attendanceBonusAmt   Int
  dailyRate            Int
  absenceDeduction     Int
  otPremium            Int
  adHocBonuses         Int
  advanceDeduction     Int
  fineDeduction        Int
  netPay               Int

  @@unique([payrollId, employeeId])
  @@index([payrollId])
  @@index([employeeId])
}

// In-app notifications (for managers: break events, leave requests, etc.)
enum NotifType {
  BREAK_OUT
  BREAK_IN
  LEAVE_REQUEST
  ATTENDANCE_APPROVED
  LEAVE_APPROVED
  LEAVE_REJECTED
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  type      NotifType
  message   String
  isRead    Boolean   @default(false)
  relatedId String?
  createdAt DateTime  @default(now())

  @@index([userId, isRead])
  @@index([userId])
}
