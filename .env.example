# =========================================================================
# QQ Hotpot BBQ — environment template.  Copy to `.env` and fill real values.
#   cp .env.example .env
# =========================================================================

# ---- App ----
NODE_ENV=production
PORT=3000

# ---- Deployed image (production) ----
# The VPS pulls this GHCR image instead of building from source.
# CI publishes :prod on every push to main.
APP_IMAGE=ghcr.io/kaungsettshinnaing/qq-hotpot:prod

# ---- Auth ----
# Secret used to sign session JWTs. MUST be long & random in production.
#   Generate:  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
AUTH_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ---- Database (PostgreSQL) ----
POSTGRES_USER=qq
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=qq
# (docker-compose overrides DATABASE_URL internally — you don't need to set it here)

# ---- Caddy reverse proxy ----
# Phase 1 — IP-only (domain not yet transferred):
#   Set APP_DOMAIN to the bare IP. Caddy serves HTTP (port 80) only for IPs.
#   APP_URL must use http:// when accessing via IP.
# Public URL (used for absolute links inside the app)
# Phase 1 — IP only (Traefik already owns port 80, so we use 8080):
APP_URL=http://187.127.106.81:8080

# Phase 2 — once qqhotpotbbq.com transfer completes, point domain to this VPS
# and set up Traefik to route the domain to this container on port 3000 internally.
# Then change to: APP_URL=https://qqhotpotbbq.com

TZ=Asia/Yangon
