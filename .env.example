# =========================================================================
# QQ Hotpot BBQ — environment template.  Copy to `.env` and fill real values.
#   cp .env.example .env
# =========================================================================

# ---- App ----
NODE_ENV=production
PORT=3000

# ---- Auth ----
# Secret used to sign session JWTs. MUST be long & random in production.
#   Generate:  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
AUTH_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# ---- Database (PostgreSQL) ----
POSTGRES_USER=qq
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=qq
# (docker-compose overrides DATABASE_URL internally — you don't need to set it here)

# ---- Caddy reverse proxy ----
# Phase 1 — IP-only (domain not yet transferred):
#   Set APP_DOMAIN to the bare IP. Caddy serves HTTP (port 80) only for IPs.
#   APP_URL must use http:// when accessing via IP.
APP_DOMAIN=187.127.106.81
APP_URL=http://187.127.106.81

# Phase 2 — once qqhotpotbbq.com transfer completes:
#   Change both lines below (Caddy will auto-provision HTTPS via Let's Encrypt):
#   APP_DOMAIN=qqhotpotbbq.com
#   APP_URL=https://qqhotpotbbq.com

# Email for Let's Encrypt registration (only used when APP_DOMAIN is a real domain):
ACME_EMAIL=kaungsettshinnaing@gmail.com

# ---- Container image (published by GitHub Actions CI) ----
APP_IMAGE=ghcr.io/kaungsettshinnaing/qq-hotpot:latest

TZ=Asia/Yangon
