# =========================================================================
# QQ Hotpot BBQ — environment template.  Copy to `.env` and fill real values.
#   cp .env.example .env
# =========================================================================

# ---- App ----
NODE_ENV=development
PORT=3000
# Public URL of the app (used for absolute links).
APP_URL=http://localhost:3000

# ---- Auth ----
# Secret used to sign session JWTs. MUST be long & random in production.
#   Generate:  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
AUTH_SECRET=dev-only-secret-change-me-to-a-long-random-string

# ---- Database (PostgreSQL) ----
POSTGRES_USER=qq
POSTGRES_PASSWORD=qq_password_change_me
POSTGRES_DB=qq
# Host-run dev points at localhost; inside docker-compose the app overrides
# this to use the `db` service hostname.
DATABASE_URL=postgresql://qq:qq_password_change_me@localhost:5432/qq?schema=public

# ---- Deploy (docker-compose + Caddy on the Hostinger VPS) ----
# Domain Caddy serves and obtains HTTPS for:
APP_DOMAIN=app.qqhotpotbbq.com
# Email used for Let's Encrypt registration:
ACME_EMAIL=admin@qqhotpotbbq.com
# Container image published by CI (ghcr.io/<owner>/<repo>):
APP_IMAGE=ghcr.io/your-org/qq-app:latest
