# UAT environment — copy to .env.uat and fill values.
# NEVER reuse production passwords here.

# ---- Deployed image (UAT) ----
# The VPS pulls this GHCR image instead of building from source.
# CI publishes :uat on every push to the uat branch.
APP_IMAGE=ghcr.io/kaungsettshinnaing/qq-hotpot:uat

# ---- Database ----
POSTGRES_USER=qq_uat
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=qq_uat

# ---- Auth ----
# Must be different from production AUTH_SECRET.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
AUTH_SECRET=CHANGE_ME_DIFFERENT_FROM_PRODUCTION

# ---- Timezone ----
TZ=Asia/Yangon
